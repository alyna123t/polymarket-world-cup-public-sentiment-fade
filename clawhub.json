{
  "emoji": "📣",
  "primaryEnv": "SIMMER_API_KEY",
  "requires": {
    "env": ["SIMMER_API_KEY"],
    "pip": ["simmer-sdk>=0.17.1"]
  },
  "envVars": [
    {
      "name": "SIMMER_API_KEY",
      "required": true,
      "description": "Simmer SDK API key"
    }
  ],
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "public_sentiment_fade.py"
  },
  "tunables": [
    {
      "env": "SIMMER_WCPSF_HYPE_YES",
      "type": "number",
      "default": 0.72,
      "range": [0.55, 0.95],
      "step": 0.01,
      "label": "Crowded YES threshold"
    },
    {
      "env": "SIMMER_WCPSF_MIN_SIGNALS",
      "type": "number",
      "default": 2,
      "range": [1, 3],
      "step": 1,
      "label": "Minimum stacked signals"
    },
    {
      "env": "SIMMER_WCPSF_MAX_POSITION",
      "type": "number",
      "default": 10,
      "range": [1, 200],
      "step": 1,
      "label": "Max position per market"
    },
    {
      "env": "SIMMER_WCPSF_DAILY_BUDGET",
      "type": "number",
      "default": 35,
      "range": [10, 1000],
      "step": 5,
      "label": "Daily budget"
    }
  ]
}
